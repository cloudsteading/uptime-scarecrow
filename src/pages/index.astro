---
import Layout from '~/layouts/Layout.astro';
import UptimeChart from '~/components/UptimeChart.astro';
import { listMonitors } from '~/lib/monitors';
import { db } from '~/lib/db';
import type { RecentCheckRow, HttpMonitorConfig } from '~/lib/db';

// Public status page. Shows monitors marked is_public = 1 only. The landing
// page that operators see is a separate auth-gated dashboard at /admin.

let monitors: Awaited<ReturnType<typeof listMonitors>> = [];
let recentByMonitor: Map<number, RecentCheckRow[]> = new Map();
type PublicIncident = { id: number; monitor_id: number; monitor_name: string; opened_at: number; resolved_at: number | null; cause: string | null };
let recentIncidents: PublicIncident[] = [];
let dbReady = true;

try {
  const all = await listMonitors();
  monitors = all.filter((m) => m.is_public === 1);

  if (monitors.length > 0) {
    const sevenDaysAgo = Math.floor(Date.now() / 1000) - 7 * 86400;
    const ids = monitors.map((m) => m.id);
    const placeholders = ids.map(() => '?').join(',');
    const checks = await db()
      .prepare(`SELECT * FROM recent_check WHERE monitor_id IN (${placeholders}) AND started_at >= ? ORDER BY started_at DESC`)
      .bind(...ids, sevenDaysAgo)
      .all<RecentCheckRow>();
    for (const c of checks.results) {
      const arr = recentByMonitor.get(c.monitor_id) ?? [];
      arr.push(c);
      recentByMonitor.set(c.monitor_id, arr);
    }

    const thirtyDaysAgo = Math.floor(Date.now() / 1000) - 30 * 86400;
    const inc = await db()
      .prepare(
        `SELECT i.id, i.monitor_id, i.opened_at, i.resolved_at, i.cause, m.name AS monitor_name
           FROM incident i JOIN monitor m ON m.id = i.monitor_id
          WHERE m.is_public = 1 AND i.opened_at >= ?
          ORDER BY i.opened_at DESC LIMIT 25`,
      )
      .bind(thirtyDaysAgo)
      .all<PublicIncident>();
    recentIncidents = inc.results;
  }
} catch {
  dbReady = false;
}

const upCount = monitors.filter((m) => !m.paused && m.state?.status === 'up').length;
const downCount = monitors.filter((m) => !m.paused && m.state?.status === 'down').length;
const pausedCount = monitors.filter((m) => m.paused).length;
const allUp = monitors.length > 0 && downCount === 0 && upCount + pausedCount === monitors.length;
const banner = monitors.length === 0
  ? { tone: 'idle', text: 'No public monitors configured' }
  : allUp
    ? { tone: 'up', text: 'All systems operational' }
    : downCount > 0
      ? { tone: 'down', text: `${downCount} of ${monitors.length} system${monitors.length === 1 ? '' : 's'} experiencing issues` }
      : { tone: 'degraded', text: 'Awaiting first check' };

function statusBadge(m: typeof monitors[number]) {
  if (m.paused) return { dot: 'bg-paused', text: 'paused', cls: 'text-paused' };
  switch (m.state?.status) {
    case 'up': return { dot: 'bg-up shadow-[0_0_8px_1px_rgba(107,143,94,0.45)]', text: 'operational', cls: 'text-up' };
    case 'down': return { dot: 'bg-down shadow-[0_0_8px_1px_rgba(168,57,44,0.45)]', text: 'down', cls: 'text-down' };
    default: return { dot: 'bg-ink-500', text: 'unknown', cls: 'text-ink-500' };
  }
}

function fmtDuration(seconds: number): string {
  if (seconds < 60) return `${seconds}s`;
  if (seconds < 3600) return `${Math.floor(seconds / 60)}m ${seconds % 60}s`;
  const h = Math.floor(seconds / 3600);
  const m = Math.floor((seconds % 3600) / 60);
  return `${h}h ${m}m`;
}

function fmtUtcShort(unix: number): string {
  return new Date(unix * 1000).toISOString().replace('T', ' ').slice(0, 16) + ' UTC';
}
---
<Layout title="Status" description="System status and uptime">
  <section class="mx-auto max-w-5xl px-6 py-12">
    <header class={`rounded-xl border p-6 ${
      banner.tone === 'up' ? 'border-up-soft bg-up-soft/15' :
      banner.tone === 'down' ? 'border-down-soft bg-down-soft/15' :
      banner.tone === 'degraded' ? 'border-degraded-soft bg-degraded-soft/15' :
      'border-ink-800 bg-ink-900/30'
    }`}>
      <div class="flex items-center gap-3">
        <span class={`inline-block w-3 h-3 rounded-full ${
          banner.tone === 'up' ? 'bg-up shadow-[0_0_12px_2px_rgba(107,143,94,0.55)]' :
          banner.tone === 'down' ? 'bg-down shadow-[0_0_12px_2px_rgba(168,57,44,0.55)]' :
          banner.tone === 'degraded' ? 'bg-degraded' :
          'bg-ink-500'
        }`}></span>
        <h1 class={`text-2xl sm:text-3xl font-bold tracking-tight ${
          banner.tone === 'up' ? 'text-up' :
          banner.tone === 'down' ? 'text-down' :
          banner.tone === 'degraded' ? 'text-degraded' :
          'text-ink-300'
        }`}>{banner.text}</h1>
      </div>
      {monitors.length > 0 && (
        <div class="mt-3 text-ink-500 text-sm">
          {upCount} operational
          {downCount > 0 ? <> · <span class="text-down">{downCount} down</span></> : null}
          {pausedCount > 0 ? <> · {pausedCount} paused</> : null}
        </div>
      )}
    </header>

    {!dbReady && (
      <div class="mt-6 rounded-lg border border-ink-800 bg-ink-900/30 p-4 text-ink-400 text-sm">
        Status data unavailable — database not yet provisioned.
      </div>
    )}

    {monitors.length === 0 && dbReady && (
      <div class="mt-8 rounded-lg border border-ink-800 bg-ink-900/30 p-8 text-center">
        <div class="text-ink-300 font-medium">No public monitors yet</div>
        <div class="text-ink-500 text-sm mt-2">Operators can mark monitors as public from the admin dashboard.</div>
      </div>
    )}

    {monitors.length > 0 && (
      <div class="mt-8 rounded-xl border border-ink-800 bg-ink-900/30 overflow-hidden">
        <div class="px-5 py-3 border-b border-ink-800 bg-ink-900/60 flex items-baseline justify-between">
          <div class="font-medium">Monitors</div>
          <div class="text-ink-500 text-xs">last 7 days</div>
        </div>
        <ul class="divide-y divide-ink-800/60">
          {monitors.map((m) => {
            const checks = recentByMonitor.get(m.id) ?? [];
            const httpCfg = m.type === 'http' ? (m.parsed_config as HttpMonitorConfig) : null;
            const badge = statusBadge(m);
            return (
              <li class="px-5 py-4 hover:bg-ink-900/40 transition-colors">
                <a href={`/m/${m.id}`} class="block">
                  <div class="flex items-baseline justify-between gap-4 mb-2">
                    <div class="min-w-0 flex-1">
                      <div class="flex items-center gap-2.5">
                        <span class={`inline-block w-2 h-2 rounded-full shrink-0 ${badge.dot}`}></span>
                        <span class="font-medium text-ink-100 truncate">{m.name}</span>
                      </div>
                      {httpCfg?.url && <div class="text-ink-500 font-mono text-xs mt-1 truncate">{httpCfg.url}</div>}
                    </div>
                    <span class={`text-sm shrink-0 ${badge.cls}`}>{badge.text}</span>
                  </div>
                  <UptimeChart checks={checks} />
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    )}

    {recentIncidents.length > 0 && (
      <div class="mt-8 rounded-xl border border-ink-800 overflow-hidden">
        <div class="px-5 py-3 bg-ink-900/60 border-b border-ink-800 font-medium">Recent incidents <span class="text-ink-500 text-xs font-normal">· last 30 days</span></div>
        <ul class="divide-y divide-ink-800/60">
          {recentIncidents.map((i) => {
            const end = i.resolved_at ?? Math.floor(Date.now() / 1000);
            const dur = end - i.opened_at;
            return (
              <li class="px-5 py-4">
                <div class="flex items-baseline justify-between gap-4">
                  <div>
                    <div class="text-ink-100 font-medium">{i.monitor_name}</div>
                    <div class="text-ink-400 text-sm mt-0.5">{i.cause ?? 'Failure'}</div>
                  </div>
                  <div class="text-right shrink-0">
                    <div class={i.resolved_at ? 'text-ink-300 text-sm' : 'text-down text-sm font-medium'}>
                      {i.resolved_at ? `resolved · ${fmtDuration(dur)}` : 'ongoing'}
                    </div>
                    <time class="text-ink-500 text-xs font-mono" datetime={new Date(i.opened_at * 1000).toISOString()} data-ts={i.opened_at}>{fmtUtcShort(i.opened_at)}</time>
                  </div>
                </div>
              </li>
            );
          })}
        </ul>
      </div>
    )}

    {dbReady && monitors.length > 0 && recentIncidents.length === 0 && (
      <div class="mt-8 rounded-lg border border-ink-800 bg-ink-900/30 p-6 text-center text-ink-500 text-sm">
        No incidents in the last 30 days.
      </div>
    )}
  </section>
</Layout>
