---
import Layout from '~/layouts/Layout.astro';

const replaces = [
  { name: 'UptimeRobot',     price: '$8/mo' },
  { name: 'Pingdom',         price: '$15/mo' },
  { name: 'Better Stack',    price: '$25/mo' },
  { name: 'Datadog Synth.',  price: '$15/test' },
  { name: 'Cronitor',        price: '$20/mo' },
  { name: 'healthchecks.io', price: '$5/mo' },
];

const primitives = [
  { name: 'Workers',           note: 'serverless compute' },
  { name: 'Durable Objects',   note: 'per-monitor scheduling via alarms' },
  { name: 'D1',                note: 'SQLite for monitors / incidents' },
  { name: 'KV',                note: 'JWKS, rate-limit, status-page cache' },
  { name: 'R2',                note: 'long-term check archive' },
  { name: 'Analytics Engine',  note: 'time-series check data' },
  { name: 'Queues',            note: 'decoupled notifications' },
  { name: 'Email Service',     note: 'native outbound alerts' },
  { name: 'Email Routing',     note: 'ack-by-reply' },
  { name: 'Cloudflare Access', note: 'auth (no app login UI)' },
  { name: 'Workers AI',        note: 'incident summaries' },
  { name: 'Turnstile',         note: 'public status-page bot gate' },
];
---
<Layout title="About — Uptime Scarecrow">
  <section class="mx-auto max-w-4xl px-6 py-16">
    <div class="inline-flex items-center gap-2 rounded-full border border-ink-800 bg-ink-900/60 px-3 py-1 text-xs text-ink-400 mb-6">
      <span class="inline-block w-1.5 h-1.5 rounded-full bg-up"></span>
      Part of <a href="https://cloudsteading.com" class="text-ink-200 hover:text-ink-50">Cloudsteading</a> — replace SaaS with Cloudflare primitives
    </div>
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight leading-[1.05]">
      Uptime monitoring,<br/>
      <span class="text-accent-500">built entirely on Cloudflare.</span>
    </h1>
    <p class="mt-6 text-lg text-ink-400 max-w-2xl">
      Uptime Scarecrow is a self-hosted, open-source uptime monitor by Cloudsteading. Deploy it to your own Cloudflare account in under five minutes; expect to pay $2–5/mo at indie scale.
    </p>

    <div class="mt-10 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-2">
      {replaces.map((r) => (
        <div class="rounded-md border border-ink-800 bg-ink-900/40 p-3">
          <div class="text-ink-300 text-sm font-medium">{r.name}</div>
          <div class="text-ink-500 text-xs">from {r.price}</div>
        </div>
      ))}
    </div>
    <p class="text-ink-600 text-xs mt-2">↑ Replaces these. Pricing approximate, per public pages.</p>

    <h2 class="text-2xl font-bold tracking-tight mt-16">Twelve Cloudflare services, no third parties.</h2>
    <p class="text-ink-400 mt-2 max-w-2xl">Every moving part has a Cloudflare-native home. No Redis, no Postgres, no third-party cron, no auth provider integration code.</p>
    <div class="mt-6 grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {primitives.map((p) => (
        <div class="flex items-start gap-3 rounded-lg border border-ink-800 bg-ink-900/40 p-4">
          <span class="mt-1 inline-block w-2 h-2 rounded-full bg-accent-500 shrink-0"></span>
          <div>
            <div class="font-mono text-sm text-ink-100">{p.name}</div>
            <div class="text-ink-500 text-xs mt-0.5">{p.note}</div>
          </div>
        </div>
      ))}
    </div>

    <h2 class="text-2xl font-bold tracking-tight mt-16">How a check flows.</h2>
    <div class="mt-4 rounded-lg border border-ink-800 bg-ink-950 p-6 font-mono text-sm text-ink-300 overflow-x-auto">
<pre class="leading-relaxed">{`Cron Trigger (* * * * *)        ← safety-net
        │
        ▼
   tick worker — re-arms DO alarms after deploys
        │
        ▼
   MonitorScheduler DO ── self-schedules via Alarm
        │
        ▼ (alarm fires)
   performCheck() — HTTP fetch + assertions
        │
        ├──► Analytics Engine — time-series points
        ├──► D1 recent_check  — 24h buffer
        └──► state machine    — open / recover incident
                  │
                  ▼ (state change)
            NOTIFY_QUEUE → Email / Slack / Discord / …`}</pre>
    </div>

    <p class="text-ink-500 text-sm mt-12">
      <a href="/" class="text-ink-200 hover:text-ink-50">← Back to dashboard</a>
    </p>
  </section>
</Layout>
