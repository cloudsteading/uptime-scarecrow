---
import Layout from '~/layouts/Layout.astro';
import { db } from '~/lib/db';

type IncidentRow = {
  id: number;
  monitor_id: number;
  monitor_name: string;
  monitor_type: 'http' | 'heartbeat';
  opened_at: number;
  resolved_at: number | null;
  cause: string | null;
};

let open: IncidentRow[] = [];
let past: IncidentRow[] = [];
let dbReady = true;

try {
  const { results } = await db()
    .prepare(
      `SELECT i.id, i.monitor_id, i.opened_at, i.resolved_at, i.cause,
              m.name AS monitor_name, m.type AS monitor_type
         FROM incident i
         JOIN monitor m ON m.id = i.monitor_id
        ORDER BY i.opened_at DESC
        LIMIT 200`,
    )
    .all<IncidentRow>();
  open = results.filter((r) => r.resolved_at === null);
  past = results.filter((r) => r.resolved_at !== null);
} catch {
  dbReady = false;
}

function fmtAbs(unix: number): string {
  return new Date(unix * 1000).toISOString().replace('T', ' ').slice(0, 19) + ' UTC';
}

function fmtDuration(seconds: number): string {
  if (seconds < 60) return `${seconds}s`;
  if (seconds < 3600) return `${Math.floor(seconds / 60)}m ${seconds % 60}s`;
  const h = Math.floor(seconds / 3600);
  const m = Math.floor((seconds % 3600) / 60);
  return `${h}h ${m}m`;
}

function durationFor(i: IncidentRow): string {
  const end = i.resolved_at ?? Math.floor(Date.now() / 1000);
  return fmtDuration(end - i.opened_at);
}
---
<Layout title="Incidents — Uptime Scarecrow">
  <div class="mx-auto max-w-6xl px-6 py-8">
    <div class="flex items-baseline justify-between flex-wrap gap-4">
      <h1 class="text-2xl font-bold tracking-tight">Incidents</h1>
      <p class="text-ink-500 text-sm">{open.length} open · {past.length} resolved (last 200)</p>
    </div>

    {!dbReady && (
      <div class="mt-6 rounded-md border border-degraded-soft bg-degraded-soft/20 p-4 text-sm text-degraded">
        D1 binding not available locally. Run <code class="font-mono text-ink-200">npm run db:migrate:local</code>.
      </div>
    )}

    <section class="mt-8">
      <h2 class="text-sm uppercase tracking-wide text-down font-medium">Open</h2>
      {open.length === 0 ? (
        <div class="mt-3 rounded-lg border border-up-soft/40 bg-up-soft/10 p-6 text-up text-sm">
          No open incidents — everything's quiet.
        </div>
      ) : (
        <div class="mt-3 rounded-lg border border-down-soft bg-down-soft/15 overflow-hidden">
          <table class="w-full text-sm">
            <thead class="text-ink-400 text-xs uppercase tracking-wide bg-down-soft/30">
              <tr>
                <th class="text-left font-medium px-4 py-3">Monitor</th>
                <th class="text-left font-medium px-4 py-3">Cause</th>
                <th class="text-right font-medium px-4 py-3">Opened</th>
                <th class="text-right font-medium px-4 py-3">Duration</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-down-soft/40">
              {open.map((i) => (
                <tr class="hover:bg-down-soft/20 transition-colors group">
                  <td class="px-4 py-3 relative">
                    <a href={`/incident/${i.id}`} class="absolute inset-0 z-10" aria-label={`Incident ${i.id}`}></a>
                    <span class="font-medium text-ink-100 group-hover:text-ink-50">{i.monitor_name}</span>
                    <span class="ml-2 px-1.5 py-0.5 rounded text-xs bg-ink-800 text-ink-400">{i.monitor_type}</span>
                  </td>
                  <td class="px-4 py-3 text-ink-300 max-w-[40ch] truncate" title={i.cause ?? ''}>{i.cause ?? '—'}</td>
                  <td class="px-4 py-3 text-right text-ink-400 font-mono text-xs">{<time datetime={new Date(i.opened_at * 1000).toISOString()} data-ts={i.opened_at}>{fmtAbs(i.opened_at)}</time>}</td>
                  <td class="px-4 py-3 text-right text-down font-mono">{durationFor(i)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </section>

    <section class="mt-10">
      <h2 class="text-sm uppercase tracking-wide text-ink-400 font-medium">Resolved</h2>
      {past.length === 0 ? (
        <div class="mt-3 rounded-lg border border-dashed border-ink-700 bg-ink-900/20 p-6 text-ink-500 text-sm">
          No past incidents yet.
        </div>
      ) : (
        <div class="mt-3 rounded-lg border border-ink-800 overflow-hidden">
          <table class="w-full text-sm">
            <thead class="text-ink-400 text-xs uppercase tracking-wide bg-ink-900/60">
              <tr>
                <th class="text-left font-medium px-4 py-3">Monitor</th>
                <th class="text-left font-medium px-4 py-3 hidden md:table-cell">Cause</th>
                <th class="text-right font-medium px-4 py-3 hidden sm:table-cell">Opened</th>
                <th class="text-right font-medium px-4 py-3 hidden sm:table-cell">Resolved</th>
                <th class="text-right font-medium px-4 py-3">Duration</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-ink-800/60">
              {past.map((i) => (
                <tr class="hover:bg-ink-900/40 transition-colors group">
                  <td class="px-4 py-3 relative">
                    <a href={`/incident/${i.id}`} class="absolute inset-0 z-10" aria-label={`Incident ${i.id}`}></a>
                    <span class="font-medium text-ink-200 group-hover:text-ink-50">{i.monitor_name}</span>
                    <span class="ml-2 px-1.5 py-0.5 rounded text-xs bg-ink-800 text-ink-400">{i.monitor_type}</span>
                  </td>
                  <td class="px-4 py-3 text-ink-400 hidden md:table-cell max-w-[40ch] truncate" title={i.cause ?? ''}>{i.cause ?? '—'}</td>
                  <td class="px-4 py-3 text-right text-ink-500 hidden sm:table-cell font-mono text-xs">{<time datetime={new Date(i.opened_at * 1000).toISOString()} data-ts={i.opened_at}>{fmtAbs(i.opened_at)}</time>}</td>
                  <td class="px-4 py-3 text-right text-ink-500 hidden sm:table-cell font-mono text-xs">{<time datetime={new Date(i.resolved_at! * 1000).toISOString()} data-ts={i.resolved_at!}>{fmtAbs(i.resolved_at!)}</time>}</td>
                  <td class="px-4 py-3 text-right text-ink-300 font-mono">{durationFor(i)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </section>
  </div>
</Layout>
