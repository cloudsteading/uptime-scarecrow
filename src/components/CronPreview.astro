---
// Live cron editor preview. Mounts next to a cron <input> and:
//   - shows quick-pick presets that fill the input
//   - validates on every keystroke
//   - renders the next 12 fire times as a list + a relative-time bar chart
//   - shows a human-readable summary ("every 5 minutes")
//
// Usage:
//   <input name="cron_expression" id="cron_expr" />
//   <CronPreview inputId="cron_expr" />

interface Props {
  inputId: string;
}
const { inputId } = Astro.props;

const presets: { label: string; expr: string }[] = [
  { label: 'Every minute',     expr: '* * * * *' },
  { label: 'Every 5 min',      expr: '*/5 * * * *' },
  { label: 'Every 15 min',     expr: '*/15 * * * *' },
  { label: 'Hourly',           expr: '0 * * * *' },
  { label: 'Daily 03:00 UTC',  expr: '0 3 * * *' },
  { label: 'Weekdays 09:00',   expr: '0 9 * * 1-5' },
  { label: 'Weekly Sun 00:00', expr: '0 0 * * 0' },
  { label: 'Monthly day-1',    expr: '0 0 1 * *' },
];
---
<div class="mt-3 cron-preview" data-cron-input-id={inputId}>
  <div class="text-xs text-ink-500 uppercase tracking-wide mb-1.5">Quick picks</div>
  <div class="flex flex-wrap gap-1.5 mb-3">
    {presets.map((p) => (
      <button type="button"
              class="cron-preset px-2 py-1 rounded-md border border-ink-800 bg-ink-900 hover:border-accent-600 hover:text-accent-300 text-ink-300 text-xs font-mono transition-colors"
              data-cron-expr={p.expr}
              title={p.expr}>{p.label}</button>
    ))}
  </div>

  <div class="rounded-md border border-ink-800 bg-ink-950/50 p-4 min-h-[140px]">
    <div class="cron-summary text-sm text-ink-400 italic">— enter a cron expression above —</div>

    <div class="cron-error hidden mt-2 text-sm text-down" data-empty=""></div>

    <div class="cron-result hidden">
      <div class="mt-3 text-xs uppercase tracking-wide text-ink-500">Next 12 runs (UTC)</div>

      <!-- timeline: relative spacing of next runs over a fixed window -->
      <div class="cron-timeline relative h-8 mt-2 mb-1 border-b border-l border-ink-800 bg-gradient-to-b from-ink-900/40 to-transparent rounded-bl-md"
           aria-hidden="true"></div>
      <div class="flex justify-between text-[10px] text-ink-600 font-mono mb-3">
        <span class="cron-timeline-start">now</span>
        <span class="cron-timeline-end"></span>
      </div>

      <ol class="cron-runs grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1 text-sm font-mono"></ol>
    </div>
  </div>
</div>

<script>
  import { nextRun, validateCron } from '~/lib/cron';

  function describe(expr: string): string {
    const t = expr.trim().toLowerCase();
    const aliases: Record<string,string> = {
      '@yearly': 'once a year, at midnight on Jan 1',
      '@annually': 'once a year, at midnight on Jan 1',
      '@monthly': 'on the 1st of each month at midnight',
      '@weekly': 'every Sunday at midnight',
      '@daily': 'every day at midnight',
      '@midnight': 'every day at midnight',
      '@hourly': 'every hour, on the hour',
    };
    if (aliases[t]) return aliases[t];
    const parts = expr.trim().split(/\s+/);
    if (parts.length !== 5) return '';
    const [m,h,dom,mo,dow] = parts;
    const allStar = parts.every(p => p === '*');
    if (allStar) return 'every minute';
    if (m === '*' && h === '*' && dom === '*' && mo === '*' && dow === '*') return 'every minute';
    const stepM = m.match(/^\*\/(\d+)$/);
    if (stepM && h === '*' && dom === '*' && mo === '*' && dow === '*') return `every ${stepM[1]} minutes`;
    const stepH = h.match(/^\*\/(\d+)$/);
    if (m === '0' && stepH && dom === '*' && mo === '*' && dow === '*') return `every ${stepH[1]} hours, on the hour`;
    if (m === '0' && h === '*' && dom === '*' && mo === '*' && dow === '*') return 'every hour, on the hour';
    if (/^\d+$/.test(m) && /^\d+$/.test(h) && dom === '*' && mo === '*' && dow === '*') {
      return `every day at ${h.padStart(2,'0')}:${m.padStart(2,'0')} UTC`;
    }
    if (/^\d+$/.test(m) && /^\d+$/.test(h) && dom === '*' && mo === '*' && /^[0-7]+(-[0-7]+)?$/.test(dow)) {
      const dayMap = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
      const range = dow.match(/^(\d)-(\d)$/);
      const days = range ? `${dayMap[+range[1]%7]}–${dayMap[+range[2]%7]}` : dayMap[+dow%7];
      return `${days} at ${h.padStart(2,'0')}:${m.padStart(2,'0')} UTC`;
    }
    return '';
  }

  function fmtNext(unixMs: number, fromMs: number): { abs: string; rel: string } {
    const d = new Date(unixMs);
    const abs = d.toISOString().replace('T', ' ').slice(0, 16) + 'Z';
    const dt = unixMs - fromMs;
    const s = Math.round(dt / 1000);
    let rel: string;
    if (s < 60) rel = `in ${s}s`;
    else if (s < 3600) rel = `in ${Math.round(s/60)}m`;
    else if (s < 86400) rel = `in ${Math.round(s/3600)}h`;
    else rel = `in ${Math.round(s/86400)}d`;
    return { abs, rel };
  }

  function computeRuns(expr: string, count = 12): number[] {
    const out: number[] = [];
    let t = Date.now();
    for (let i = 0; i < count; i++) {
      t = nextRun(expr, t);
      out.push(t);
    }
    return out;
  }

  document.querySelectorAll<HTMLElement>('.cron-preview').forEach((root) => {
    const inputId = root.dataset.cronInputId!;
    const input = document.getElementById(inputId) as HTMLInputElement | null;
    if (!input) return;

    const summaryEl = root.querySelector<HTMLElement>('.cron-summary')!;
    const errorEl = root.querySelector<HTMLElement>('.cron-error')!;
    const resultEl = root.querySelector<HTMLElement>('.cron-result')!;
    const runsEl = root.querySelector<HTMLOListElement>('.cron-runs')!;
    const timelineEl = root.querySelector<HTMLElement>('.cron-timeline')!;
    const endEl = root.querySelector<HTMLElement>('.cron-timeline-end')!;

    function update() {
      const expr = input!.value.trim();
      if (!expr) {
        summaryEl.textContent = '— enter a cron expression above —';
        summaryEl.classList.remove('hidden');
        errorEl.classList.add('hidden');
        resultEl.classList.add('hidden');
        return;
      }
      const v = validateCron(expr);
      if (!v.ok) {
        summaryEl.classList.add('hidden');
        errorEl.textContent = v.error;
        errorEl.classList.remove('hidden');
        resultEl.classList.add('hidden');
        return;
      }
      let runs: number[];
      try { runs = computeRuns(expr, 12); } catch (e) {
        summaryEl.classList.add('hidden');
        errorEl.textContent = (e as Error).message;
        errorEl.classList.remove('hidden');
        resultEl.classList.add('hidden');
        return;
      }
      const now = Date.now();
      const desc = describe(expr);
      summaryEl.textContent = desc ? `Runs ${desc}.` : 'Schedule preview:';
      summaryEl.classList.remove('hidden', 'italic');
      summaryEl.classList.add('text-ink-200');
      errorEl.classList.add('hidden');
      resultEl.classList.remove('hidden');

      // timeline window = first 4 runs, capped at 1 hour minimum so
      // hourly schedules don't crowd into a sliver.
      const tStart = now;
      const tEnd = Math.max(runs[Math.min(3, runs.length - 1)], now + 60_000);
      const span = tEnd - tStart;
      timelineEl.innerHTML = '';
      for (const r of runs) {
        if (r > tEnd) break;
        const x = ((r - tStart) / span) * 100;
        const tick = document.createElement('div');
        tick.className = 'absolute top-0 bottom-0 w-px bg-accent-500';
        tick.style.left = `${x}%`;
        const dot = document.createElement('div');
        dot.className = 'absolute -translate-x-1/2 w-1.5 h-1.5 rounded-full bg-accent-500 shadow-[0_0_6px_rgba(217,122,43,0.6)]';
        dot.style.left = `${x}%`;
        dot.style.top = '0';
        timelineEl.appendChild(tick);
        timelineEl.appendChild(dot);
      }
      endEl.textContent = `+${Math.round(span / 60_000)}m`;

      runsEl.innerHTML = '';
      for (let i = 0; i < runs.length; i++) {
        const { abs, rel } = fmtNext(runs[i], now);
        const li = document.createElement('li');
        li.className = 'flex items-baseline gap-3 py-0.5';
        li.innerHTML =
          '<span class="text-ink-500 text-xs w-4 text-right">' + (i + 1) + '.</span>' +
          '<span class="text-ink-200">' + abs + '</span>' +
          '<span class="text-ink-500 text-xs ml-auto">' + rel + '</span>';
        runsEl.appendChild(li);
      }
    }

    input.addEventListener('input', update);

    root.querySelectorAll<HTMLButtonElement>('.cron-preset').forEach((btn) => {
      btn.addEventListener('click', () => {
        input.value = btn.dataset.cronExpr || '';
        // Also flip the schedule_kind radio to "cron" if present.
        const cronRadio = document.querySelector<HTMLInputElement>('input[name="schedule_kind"][value="cron"]');
        if (cronRadio) cronRadio.checked = true;
        update();
        input.focus();
      });
    });

    update();
  });
</script>
