---
import '~/styles/global.css';
import ScarecrowLogo from '~/components/ScarecrowLogo.astro';

interface Props {
  title?: string;
  description?: string;
  containerClass?: string;
}

const {
  title = 'Uptime Scarecrow',
  description = 'Self-hosted uptime monitoring on Cloudflare — by Cloudsteading.',
  containerClass = 'mx-auto max-w-6xl px-6',
} = Astro.props;

const user = Astro.locals.user;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark" />
  </head>
  <body class="bg-ink-950 text-ink-100 font-sans">
    <header class="border-b border-ink-800 bg-ink-950/70 backdrop-blur sticky top-0 z-30">
      <div class={`${containerClass} flex items-center justify-between h-14`}>
        <a href="/" class="flex items-center gap-2.5 font-semibold tracking-tight">
          <ScarecrowLogo size={26} />
          <span>uptime scarecrow</span>
        </a>
        <nav class="flex items-center gap-1 text-sm">
          <a href="/" class="px-3 py-1.5 rounded-md text-ink-300 hover:text-ink-50 hover:bg-ink-800/60">Monitors</a>
          <a href="/incidents" class="px-3 py-1.5 rounded-md text-ink-300 hover:text-ink-50 hover:bg-ink-800/60">Incidents</a>
          <a href="/settings" class="px-3 py-1.5 rounded-md text-ink-300 hover:text-ink-50 hover:bg-ink-800/60">Settings</a>
          <a href="/about" class="px-3 py-1.5 rounded-md text-ink-500 hover:text-ink-200 hover:bg-ink-800/60">About</a>
          {user && (
            <span class="ml-3 px-3 py-1.5 rounded-md text-ink-400 text-xs font-mono">{user.email}</span>
          )}
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-24 border-t border-ink-800 py-10 text-sm text-ink-500">
      <div class={`${containerClass} flex flex-col sm:flex-row items-start sm:items-center gap-4 justify-between`}>
        <div><span class="text-ink-400">uptime scarecrow</span> — built on Cloudflare by <a href="https://cloudsteading.com" class="hover:text-ink-300">Cloudsteading</a>. MIT licensed.</div>
        <div class="flex items-center gap-4">
          <a href="https://github.com/cloudsteading/uptime-scarecrow" class="hover:text-ink-300">GitHub</a>
        </div>
      </div>
    </footer>
  </body>
</html>
