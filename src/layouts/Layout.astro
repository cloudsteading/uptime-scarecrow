---
import '~/styles/global.css';
import ScarecrowLogo from '~/components/ScarecrowLogo.astro';

interface Props {
  title?: string;
  description?: string;
  containerClass?: string;
}

const {
  title = 'Uptime Scarecrow',
  description = 'Self-hosted uptime monitoring on Cloudflare — by Cloudsteading.',
  containerClass = 'mx-auto max-w-6xl px-6',
} = Astro.props;

const user = Astro.locals.user;
const flash = Astro.locals.flash;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark" />
    {flash && <meta name="x-flash" data-msg={flash.msg} data-kind={flash.kind} />}
  </head>
  <body class="bg-ink-950 text-ink-100 font-sans">
    <header class="border-b border-ink-800 bg-ink-950/70 backdrop-blur sticky top-0 z-30">
      <div class={`${containerClass} flex items-center justify-between h-14`}>
        <a href={user ? '/admin' : '/'} class="flex items-center gap-2.5 font-semibold tracking-tight">
          <ScarecrowLogo size={26} />
          <span>uptime scarecrow</span>
        </a>
        <nav class="flex items-center gap-1 text-sm">
          {user ? (
            <>
              <a href="/admin" class="px-3 py-1.5 rounded-md text-ink-300 hover:text-ink-50 hover:bg-ink-800/60">Monitors</a>
              <a href="/admin/incidents" class="px-3 py-1.5 rounded-md text-ink-300 hover:text-ink-50 hover:bg-ink-800/60">Incidents</a>
              <a href="/admin/settings" class="px-3 py-1.5 rounded-md text-ink-300 hover:text-ink-50 hover:bg-ink-800/60">Settings</a>
              <a href="/" class="px-3 py-1.5 rounded-md text-ink-500 hover:text-ink-200 hover:bg-ink-800/60">Public ↗</a>
              <span class="ml-3 px-3 py-1.5 rounded-md text-ink-400 text-xs font-mono">{user.email}</span>
            </>
          ) : null}
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-24 border-t border-ink-800 py-10 text-sm text-ink-500">
      <div class={`${containerClass} flex flex-col sm:flex-row items-start sm:items-center gap-4 justify-between`}>
        <div><span class="text-ink-400">uptime scarecrow</span> — built on Cloudflare by <a href="https://cloudsteading.com" class="hover:text-ink-300">Cloudsteading</a>. MIT licensed.</div>
        <div class="flex items-center gap-4">
          <a href="https://github.com/cloudsteading/uptime-scarecrow" class="hover:text-ink-300">GitHub</a>
        </div>
      </div>
    </footer>

    <!-- Shared floating tooltip for any element with [data-tip]. Replaces native SVG <title> hovers (which have a long delay and unstyled UA chrome). data-tip values may contain \n (rendered as line breaks via whitespace-pre-line) and {LOCAL:<unix>} placeholders that get replaced with the viewer's local time on hover. -->
    <div id="hover-tip" role="tooltip" class="hidden fixed z-50 pointer-events-none px-2.5 py-1.5 rounded-md border border-ink-700 bg-ink-950/95 backdrop-blur text-[11px] font-mono text-ink-100 shadow-[0_4px_12px_rgba(0,0,0,0.5)] whitespace-pre-line max-w-sm leading-relaxed"></div>

    <!-- Toast stack. Auto-shows any ?flash=msg&flash_kind=ok|err query param on
         page load, then strips those params from the URL so refresh doesn't
         re-show. window.toast(text, 'ok'|'err') is also exposed for in-page JS. -->
    <div id="toast-stack" aria-live="polite" class="fixed bottom-4 right-4 z-50 flex flex-col-reverse gap-2 max-w-sm pointer-events-none"></div>
    <script is:inline>
      // Toast system. Reads flash data from a server-emitted <meta name="x-flash">
      // tag (set by middleware from the single-use flash cookie). The cookie is
      // already cleared by the response middleware so refresh won't re-show.
      // window.toast(text, 'ok'|'err') is also exposed for client-driven toasts.
      (() => {
        const stack = document.getElementById('toast-stack');
        if (!stack) return;
        function show(text, kind) {
          const isErr = kind === 'err';
          const t = document.createElement('div');
          t.className = `pointer-events-auto rounded-md border px-3.5 py-2.5 text-sm shadow-[0_8px_24px_rgba(0,0,0,0.5)] backdrop-blur transition duration-200 opacity-0 translate-x-3 cursor-pointer ${
            isErr
              ? 'border-down/60 bg-down-soft/40 text-ink-100'
              : 'border-up/60 bg-up-soft/40 text-ink-100'
          }`;
          const dot = document.createElement('span');
          dot.className = `inline-block w-1.5 h-1.5 rounded-full mr-2 align-middle ${isErr ? 'bg-down' : 'bg-up'}`;
          const span = document.createElement('span');
          span.className = 'align-middle';
          span.textContent = text;
          t.appendChild(dot);
          t.appendChild(span);
          stack.appendChild(t);
          requestAnimationFrame(() => { t.classList.remove('opacity-0', 'translate-x-3'); });
          const dismiss = () => {
            t.classList.add('opacity-0', 'translate-x-3');
            setTimeout(() => t.remove(), 220);
          };
          t.addEventListener('click', dismiss);
          setTimeout(dismiss, 4000);
        }
        window.toast = show;
        const meta = document.querySelector('meta[name="x-flash"]');
        if (meta) {
          const msg = meta.getAttribute('data-msg');
          const kind = meta.getAttribute('data-kind') === 'err' ? 'err' : 'ok';
          if (msg) show(msg, kind);
        }
      })();

      (() => {
        // Local time is the viewer's machine clock — server can't know it, so
        // we always emit UTC at SSR and let this script append local alongside.
        function fmtLocal(sec) {
          const d = new Date(sec * 1000);
          if (Number.isNaN(d.getTime())) return '';
          return d.toLocaleString(undefined, {
            weekday: 'short', month: 'short', day: 'numeric',
            hour: 'numeric', minute: '2-digit',
            timeZoneName: 'short',
          });
        }
        function expandLocal(text) {
          return text.replace(/\{LOCAL:(\d+)\}/g, (_, s) => fmtLocal(parseInt(s, 10)));
        }

        // Static elements with data-ts get a sibling <span> with the local time.
        function enhanceStatic(root) {
          (root || document).querySelectorAll('[data-ts]:not([data-ts-done])').forEach((el) => {
            el.setAttribute('data-ts-done', '1');
            const sec = parseInt(el.getAttribute('data-ts') || '', 10);
            if (!Number.isFinite(sec)) return;
            const local = document.createElement('span');
            local.className = 'block text-ink-600 text-[10px] font-mono mt-0.5';
            local.textContent = '↳ ' + fmtLocal(sec) + ' (local)';
            el.parentNode.insertBefore(local, el.nextSibling);
          });
        }
        enhanceStatic(document);
        // Re-run after Astro view transitions or any later DOM mutations.
        document.addEventListener('astro:page-load', () => enhanceStatic(document));

        // Tooltip overlay
        const tip = document.getElementById('hover-tip');
        if (!tip) return;
        let active = null;
        function show(el, x, y) {
          tip.textContent = expandLocal(el.getAttribute('data-tip') || '');
          tip.classList.remove('hidden');
          const rect = tip.getBoundingClientRect();
          const margin = 10;
          let left = x - rect.width / 2;
          let top = y - rect.height - margin;
          if (top < 4) top = y + margin + 4;
          left = Math.max(4, Math.min(left, window.innerWidth - rect.width - 4));
          tip.style.left = left + 'px';
          tip.style.top = top + 'px';
        }
        function hide() { active = null; tip.classList.add('hidden'); }
        document.addEventListener('pointermove', (e) => {
          const t = e.target instanceof Element ? e.target.closest('[data-tip]') : null;
          if (t) {
            active = t;
            show(t, e.clientX, e.clientY);
          } else if (active) {
            hide();
          }
        });
        document.addEventListener('pointerleave', hide, true);
        document.addEventListener('scroll', hide, true);
      })();
    </script>
  </body>
</html>
