{
  "name": "uptime-scarecrow",
  "description": "Self-hosted uptime monitoring on Cloudflare — by Cloudsteading.",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://github.com/cloudsteading/uptime-scarecrow",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cloudsteading/uptime-scarecrow.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "concurrently --names APP,SCHED,ARM --prefix-colors cyan,magenta,yellow --kill-others-on-fail \"npm:dev:app\" \"npm:dev:scheduler\" \"npm:dev:arm-once\"",
    "dev:app": "astro dev --port 4322",
    "dev:scheduler": "wrangler dev -c wrangler.scheduler.jsonc --port 8788 --test-scheduled",
    "dev:arm-once": "until curl -fsS -o /dev/null 'http://localhost:8788/__scheduled?cron=*+*+*+*+*'; do sleep 2; done; echo 'alarms armed via per-minute cron tick'",
    "build": "astro build",
    "preview": "wrangler dev",
    "astro": "astro",
    "db:create": "wrangler d1 create uptime-scarecrow-db",
    "db:migrate:local": "wrangler d1 migrations apply uptime-scarecrow-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply uptime-scarecrow-db --remote",
    "tick:arm": "curl -fsS 'http://localhost:8788/__scheduled?cron=*+*+*+*+*'",
    "tick:rollup": "curl -fsS 'http://localhost:8788/__scheduled?cron=5+0+*+*+*'",
    "tick:prune": "curl -fsS 'http://localhost:8788/__scheduled?cron=15+0+*+*+*'",
    "deploy:app": "astro build && wrangler deploy",
    "deploy:scheduler": "wrangler deploy -c wrangler.scheduler.jsonc",
    "deploy": "npm run deploy:scheduler && npm run deploy:app"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.10",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.8",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^4.20260420.1",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.83.0"
  },
  "overrides": {
    "vite": "^7"
  }
}
